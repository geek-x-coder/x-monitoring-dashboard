# IIS 단일 사이트(IIS+ARR) 배포용 환경 변수
# `npm run build:iis` (vite build --mode iis) 실행 시 자동으로 로드됨
#
# 프론트엔드와 백엔드가 같은 origin(같은 IIS 포트)이므로 VITE_API_URL은 빈 문자열.
# services/http.js 에서 빈 문자열을 same-origin 모드로 인식하여
# 현재 window.location.origin 으로 호출 → IIS rewrite 규칙이 Flask로 프록시.
VITE_API_URL=

# 자동 갱신 주기 (ms)
VITE_REFRESH_INTERVAL=5000

# 디버그 모드
VITE_DEBUG=false

# 프론트엔드 버전
VITE_APP_VERSION=2.0.0
